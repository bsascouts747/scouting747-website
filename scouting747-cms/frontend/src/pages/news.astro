---
import Layout from "../layouts/Layout.astro";
import { sanityClient } from "sanity:client";
import { urlFor, buildSrcSet } from "../utils/image";
import { formatDate } from "../utils";
import "../styles/global.css";

const posts = await sanityClient.fetch<Array<any>>(`
  *[_type == "post"] | order(coalesce(eventDate, _createdAt) desc) {
    title,
    slug,
    eventDate,
    _createdAt,
    author,
    mainImage,
    excerpt
  }
`);
---

<Layout title="News & Highlights | Troop 747" description="All news, stories, and highlights from BSA Troop 747.">
  <div class="max-w-[1440px] 2xl:max-w-[1800px] mx-auto px-4 sm:px-8 md:px-12 lg:px-16 w-full py-12">

    <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 hover:text-emerald-800 transition mb-8 group">
      <span class="transition-transform group-hover:-translate-x-1">←</span> Back to Home
    </a>

    <div class="mb-10">
      <h1 class="text-3xl sm:text-5xl font-black text-slate-900 tracking-tight">News & Highlights</h1>
      <p class="text-slate-500 mt-2">All stories written by our scouts and leaders.</p>
    </div>

    <div class="grid gap-8 md:grid-cols-2 w-full">
      {posts.map((post) => (
        <article class="flex flex-col xl:flex-row gap-6 bg-white p-5 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition duration-300">

          <div class="w-full xl:w-56 h-48 xl:h-auto rounded-xl overflow-hidden shrink-0 shadow-inner relative flex items-center justify-center bg-slate-100">
            {post.mainImage ? (
              <img
                src={urlFor(post.mainImage).width(500).auto("format").quality(80).url()}
                srcset={buildSrcSet(post.mainImage, [300, 500], 80)}
                alt={post.mainImage.alt || post.title}
                class="w-full h-full object-cover transition duration-500 hover:scale-105"
              />
            ) : (
              <div class="w-full h-full bg-[#1e293b] flex items-center justify-center p-6">
                <img
                  src="/images/logo.png"
                  alt="BSA Troop 747 Logo"
                  class="max-w-full max-h-full object-contain select-none pointer-events-none"
                />
              </div>
            )}
          </div>

          <div class="flex flex-col justify-between py-1 flex-1">
            <div>
              <time class="text-xs font-semibold text-emerald-700 tracking-wider uppercase">
                📅 {post.eventDate ? formatDate(post.eventDate) : formatDate(post._createdAt)}
              </time>
              <h3 class="text-2xl font-bold text-slate-900 mt-1 hover:text-emerald-700 transition leading-snug">
                <a href={`/post/${post.slug.current}`}>{post.title}</a>
              </h3>
              <p class="text-sm text-slate-600 mt-3 line-clamp-3 leading-relaxed">
                {post.excerpt || "Click to read the full details of this recent post."}
              </p>
            </div>

            {post.author && (
              <div class="flex items-center gap-2 mt-6">
                <div class="w-7 h-7 rounded-full bg-emerald-800 flex items-center justify-center text-[10px] font-bold text-white shadow-sm">🪶</div>
                <span class="text-xs font-bold text-slate-700">{post.author}</span>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>

  </div>
</Layout>