---
// src/pages/post/[slug].astro
import Layout from "../../layouts/Layout.astro";
import { sanityClient } from "sanity:client";
import { urlFor } from "../../utils/image";
import { formatDate } from "../../utils";
import { PortableText } from "astro-portabletext";
import PortableTextImage from "../../components/PortableTextImage.astro";

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "post" && defined(slug.current)]`);
  return posts.map((post: any) => ({
    params: { slug: post.slug.current },
    props: { post },
  }));
}

const { post } = Astro.props as { post: any };

const customComponents = {
  type: {
    image: PortableTextImage,
  },
};
---

<Layout title={`${post.title} | Troop 747`} description={post.excerpt || ""}>
  <div class="max-w-[1440px] 2xl:max-w-[1800px] mx-auto px-4 sm:px-8 md:px-12 lg:px-16 w-full py-12">
    
    <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 hover:text-emerald-800 transition mb-8 group">
      <span class="transition-transform group-hover:-translate-x-1">←</span> Back to Home
    </a>

    <article class="max-w-4xl mx-auto">
      
      <header class="mb-8 text-center sm:text-left">
        <div class="flex flex-wrap items-center justify-center sm:justify-start gap-2 text-xs font-bold tracking-wider uppercase mb-3">
          <span class="text-emerald-700">
            📅 Event Date: {post.eventDate ? formatDate(post.eventDate) : "N/A"}
          </span>
          <span class="text-slate-300 mx-1">•</span>
          <span class="text-slate-400 font-medium">
            Posted: {formatDate(post._createdAt)}
          </span>
        </div>

        <h1 class="text-3xl sm:text-5xl font-black text-slate-900 tracking-tight leading-tight">
          {post.title}
        </h1>
        
        {post.author && (
          <div class="flex items-center justify-center sm:justify-start gap-3 mt-6">
            <div class="w-10 h-10 rounded-full bg-emerald-800 flex items-center justify-center text-sm font-bold text-white shadow-md">🪶</div>
            <div>
              <span class="block text-sm font-bold text-slate-800 leading-none">{post.author.name}</span>
              <span class="text-xs text-slate-400 mt-1 block">Troop 747 Contributor</span>
            </div>
          </div>
        )}
      </header>

      <div class="w-full max-h-[500px] aspect-video rounded-2xl overflow-hidden shadow-md border border-slate-200 mb-12 bg-slate-100 flex items-center justify-center">
        {post.mainImage ? (
          <img 
            src={urlFor(post.mainImage).width(1200).auto("format").quality(95).url()} 
            alt={post.mainImage.alt || post.title} 
            class="w-full h-full object-cover object-center" 
          />
        ) : (
        /* 📸 This points straight to your public image asset folder */
        <img 
          src="/images/fallback.webp" 
          alt="Troop 747 News Default Banner" 
          class="w-full h-full object-cover object-center" 
        />
        )}
      </div>
        ) : (
          /* Clean, modern vectors for your placeholder graphic */
          <div class="w-full h-full bg-gradient-to-br from-emerald-800 to-emerald-950 flex flex-col items-center justify-center text-emerald-100/60 p-6">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-16 h-16 opacity-40 mb-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v14.25A2.25 2.25 0 0 0 5.25 19.5h13.5A2.25 2.25 0 0 0 21 17.25V3m-18.75 0h18.75M3.75 6h16.5M3.75 9h16.5M3.75 12h16.5m-13.5 3h13.5" />
            </svg>
            <span class="text-xs font-bold tracking-widest uppercase opacity-50">Troop 747 News Feed</span>
          </div>
        )}
      </div>

      <div class="prose prose-slate max-w-none prose-headings:font-bold prose-headings:text-slate-900 prose-p:text-slate-600 prose-p:leading-relaxed prose-a:text-emerald-700 hover:prose-a:text-emerald-800 prose-strong:text-slate-900">
        <PortableText value={post.body} components={customComponents} />
      </div>

    </article>
  </div>
</Layout>