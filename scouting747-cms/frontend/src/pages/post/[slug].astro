---
// src/pages/post/[slug].astro
import Layout from "../../layouts/Layout.astro";
import { sanityClient } from "sanity:client";
import { urlFor } from "../../utils/image";
import { formatDate } from "../../utils";
import { PortableText } from "astro-portabletext";
import PortableTextImage from "../../components/PortableTextImage.astro";
import "../../styles/global.css"; // 👈 Ensures styling matches perfectly on nested routes

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`
    *[_type == "post" && defined(slug.current)] {
      ...,
      gallery[] {
        asset->,
        alt
      }
    }
  `);
  return posts.map((post: any) => ({
    params: { slug: post.slug.current },
    props: { post },
  }));
}

const { post } = Astro.props as { post: any };

const customComponents = {
  type: {
    image: PortableTextImage,
  },
};
---

<Layout title={`${post.title} | Troop 747`} description={post.excerpt || ""}>
  <div
    class="max-w-[1440px] 2xl:max-w-[1800px] mx-auto px-4 sm:px-8 md:px-12 lg:px-16 w-full py-12"
  >
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 hover:text-emerald-800 transition mb-8 group"
    >
      <span class="transition-transform group-hover:-translate-x-1">←</span> Back
      to Home
    </a>

    <article class="max-w-4xl mx-auto">
      <header class="mb-8 text-center sm:text-left">
        <div
          class="flex flex-wrap items-center justify-center sm:justify-start gap-2 text-xs font-bold tracking-wider uppercase mb-3"
        >
          <span class="text-emerald-700">
            📅 Event Date: {post.eventDate ? formatDate(post.eventDate) : "N/A"}
          </span>
          <span class="text-slate-300 mx-1">•</span>
          <span class="text-slate-400 font-medium">
            Posted: {formatDate(post._createdAt)}
          </span>
        </div>
        <h1
          class="text-3xl sm:text-5xl font-black text-slate-900 tracking-tight leading-tight"
        >
          {post.title}
        </h1>

        {
          post.author && (
            <div class="flex items-center justify-center sm:justify-start gap-3 mt-6">
              <div class="w-10 h-10 rounded-full bg-emerald-800 flex items-center justify-center text-sm font-bold text-white shadow-md">
                🪶
              </div>
              <div>
                <span class="block text-sm font-bold text-slate-800 leading-none">
                  {post.author}
                </span>
                <span class="text-xs text-slate-400 mt-1 block">
                  Troop 747 Contributor
                </span>
              </div>
            </div>
          )
        }
      </header>

      <div
        class="w-full rounded-2xl overflow-hidden shadow-md border border-slate-200 mb-12 bg-slate-100 flex items-center justify-center"
      >
        {
          post.mainImage ? (
            <img
              src={urlFor(post.mainImage)
                .width(1200)
                .auto("format")
                .quality(95)
                .url()}
              alt={post.mainImage.alt || post.title}
              class="max-h-[600px] max-w-full object-contain"
            />
          ) : (
            <div class="w-full h-64 bg-[#1e293b] flex items-center justify-center p-8 sm:p-16">
              <img
                src="/images/logo.png"
                alt="BSA Troop 747 Logo"
                class="max-w-[80%] max-h-[60%] object-contain select-none pointer-events-none"
              />
            </div>
          )
        }
      </div>
    </article>

    <div
      class="prose prose-slate max-w-none prose-headings:font-bold prose-headings:text-slate-900 prose-p:text-slate-600 prose-p:leading-relaxed prose-a:text-emerald-700 hover:prose-a:text-emerald-800 prose-strong:text-slate-900"
    >
      <PortableText value={post.body} components={customComponents} />
    </div>
    {
      post.gallery && post.gallery.length > 0 && (
        <div class="mt-16">
          <h2 class="text-2xl font-bold text-slate-900 mb-6">Photo Gallery</h2>

          {/* Grid */}
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {post.gallery.map((photo: any, index: number) => (
              <button
                data-gallery-index={index}
                class="aspect-square rounded-xl overflow-hidden bg-slate-100 hover:opacity-90 transition duration-300 hover:scale-[1.02] group cursor-pointer"
              >
                <img
                  src={urlFor(photo)
                    .width(600)
                    .auto("format")
                    .quality(80)
                    .url()}
                  alt={photo.alt || `Gallery photo ${index + 1}`}
                  class="w-full h-full object-cover"
                />
              </button>
            ))}
          </div>

          {/* Lightbox overlay */}
          <div
            id="lightbox"
            class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center p-4"
            onclick="closeLightbox()"
          >
            <button
              data-lightbox-close
              class="absolute top-4 right-4 text-white text-3xl font-bold hover:text-emerald-400 transition z-10"
            >
              ✕
            </button>
            <button
              data-lightbox-prev
              class="absolute left-4 text-white text-3xl font-bold hover:text-emerald-400 transition z-10"
            >
              ‹
            </button>
            <button
              data-lightbox-next
              class="absolute right-16 text-white text-3xl font-bold hover:text-emerald-400 transition z-10"
            >
              ›
            </button>
            <img
              id="lightbox-img"
              src=""
              alt=""
              class="max-h-[90vh] max-w-[90vw] object-contain rounded-xl shadow-2xl"
              onclick="event.stopPropagation()"
            />
            <p
              id="lightbox-counter"
              class="absolute bottom-4 text-white text-sm font-medium"
            />
          </div>
        </div>
      )
    }

    {/* Lightbox JavaScript */}
    <script
      define:vars={{
        galleryUrls: post.gallery
          ? post.gallery.map((p: any) =>
              urlFor(p).width(1400).auto("format").quality(90).url(),
            )
          : [],
      }}
    >
      let currentIndex = 0;

      function openLightbox(index) {
        currentIndex = index;
        updateLightbox();
        const lb = document.getElementById("lightbox");
        lb.classList.remove("hidden");
        lb.classList.add("flex");
        document.body.style.overflow = "hidden";
      }

      function closeLightbox() {
        const lb = document.getElementById("lightbox");
        lb.classList.add("hidden");
        lb.classList.remove("flex");
        document.body.style.overflow = "";
      }

      function nextPhoto() {
        currentIndex = (currentIndex + 1) % galleryUrls.length;
        updateLightbox();
      }

      function prevPhoto() {
        currentIndex =
          (currentIndex - 1 + galleryUrls.length) % galleryUrls.length;
        updateLightbox();
      }

      function updateLightbox() {
        document.getElementById("lightbox-img").src = galleryUrls[currentIndex];
        document.getElementById("lightbox-counter").textContent =
          `${currentIndex + 1} / ${galleryUrls.length}`;
      }

      // Wire up gallery buttons via data attributes
      document.querySelectorAll("[data-gallery-index]").forEach((btn) => {
        btn.addEventListener("click", () => {
          openLightbox(parseInt(btn.getAttribute("data-gallery-index")));
        });
      });

      // Wire up lightbox controls
      document
        .getElementById("lightbox")
        .addEventListener("click", closeLightbox);
      document
        .getElementById("lightbox-img")
        .addEventListener("click", (e) => e.stopPropagation());

      document.querySelectorAll("[data-lightbox-prev]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          prevPhoto();
        });
      });
      document.querySelectorAll("[data-lightbox-next]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          nextPhoto();
        });
      });
      document.querySelectorAll("[data-lightbox-close]").forEach((btn) => {
        btn.addEventListener("click", closeLightbox);
      });

      // Keyboard navigation
      document.addEventListener("keydown", (e) => {
        const lb = document.getElementById("lightbox");
        if (lb.classList.contains("hidden")) return;
        if (e.key === "ArrowRight") nextPhoto();
        if (e.key === "ArrowLeft") prevPhoto();
        if (e.key === "Escape") closeLightbox();
      });
    </script>
  </div>
</Layout>
