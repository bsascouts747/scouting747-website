---
// src/pages/post/[slug].astro
import Layout from "../../layouts/Layout.astro";
import { sanityClient } from "sanity:client";
import { urlFor } from "../../utils/image";
import { formatDate } from "../../utils";
import { PortableText } from "astro-portabletext";
import PortableTextImage from "../../components/PortableTextImage.astro";

// Tell Astro which dynamic posts to generate during build time
export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "post" && defined(slug.current)]`);
  return posts.map((post: any) => ({
    params: { slug: post.slug.current },
    props: { post },
  }));
}

// 🏛️ Add ': any' here to tell TypeScript it's perfectly safe to look inside the object
const { post } = Astro.props as { post: any };

const customComponents = {
  type: {
    image: PortableTextImage,
  },
};
---

<Layout title={`${post.title} | Troop 747`} description={post.excerpt || ""}>
  <div class="max-w-[1440px] 2xl:max-w-[1800px] mx-auto px-4 sm:px-8 md:px-12 lg:px-16 w-full py-12">
    
    <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 hover:text-emerald-800 transition mb-8 group">
      <span class="transition-transform group-hover:-translate-x-1">←</span> Back to Home
    </a>

    <article class="max-w-4xl mx-auto">
      
      <header class="mb-8 text-center sm:text-left">
        <time class="text-xs font-bold text-emerald-700 tracking-wider uppercase block mb-3">
          {formatDate(post._createdAt)}
        </time>
        <h1 class="text-3xl sm:text-5xl font-black text-slate-900 tracking-tight leading-tight">
          {post.title}
        </h1>
        
        {post.author && (
          <div class="flex items-center justify-center sm:justify-start gap-3 mt-6">
            <div class="w-10 h-10 rounded-full bg-emerald-800 flex items-center justify-center text-sm font-bold text-white shadow-md">🪶</div>
            <div>
              <span class="block text-sm font-bold text-slate-800 leading-none">{post.author.name}</span>
              <span class="text-xs text-slate-400 mt-1 block">Troop 747 Contributor</span>
            </div>
          </div>
        )}
      </header>

      {post.mainImage && (
        <div class="w-full aspect-[21/9] rounded-2xl overflow-hidden shadow-md border border-slate-200 mb-12 bg-slate-100">
          <img 
            src={urlFor(post.mainImage).width(1200).auto("format").quality(85).url()} 
            alt={post.mainImage.alt || post.title} 
            class="w-full h-full object-cover"
          />
        </div>
      )}

      <div class="prose prose-slate max-w-none prose-headings:font-bold prose-headings:text-slate-900 prose-p:text-slate-600 prose-p:leading-relaxed prose-a:text-emerald-700 hover:prose-a:text-emerald-800 prose-strong:text-slate-900">
        <PortableText value={post.body} components={customComponents} />
      </div>

    </article>
  </div>
</Layout>