---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import { sanityClient } from "sanity:client";
import { urlFor, buildSrcSet } from "../utils/image";
import { formatDate } from "../utils";
import "../styles/global.css"; // 👈 Restores Tailwind CSS!

// ==========================================
// 🔌 GOOGLE CALENDAR API INTEGRATION
// ==========================================
const MEETINGS_CALENDAR_ID =
  "89a8710b889a078fbbe7e37d71df9b4bf7bb4df99ff6d520a70315fcd90ef1dc@group.calendar.google.com";
const EVENTS_CALENDAR_ID =
  "4c20c9d115ad537933ec4d65b285dcb1683f7e46e48f57120bdf5d0062df1d8e@group.calendar.google.com";
const API_KEY = import.meta.env.GOOGLE_CALENDAR_API_KEY;
const timeMin = new Date().toISOString();

let nextMeeting = null;
let upcomingEvents = [];
let calendarError = false;

try {
  // Fetch next single meeting
  const meetingsRes = await fetch(
    `https://www.googleapis.com/calendar/v3/calendars/${encodeURIComponent(MEETINGS_CALENDAR_ID)}/events?key=${API_KEY}&timeMin=${timeMin}&maxResults=1&singleEvents=true&orderBy=startTime`,
  );

  // Fetch next 3 troop events
  const eventsRes = await fetch(
    `https://www.googleapis.com/calendar/v3/calendars/${encodeURIComponent(EVENTS_CALENDAR_ID)}/events?key=${API_KEY}&timeMin=${timeMin}&maxResults=3&singleEvents=true&orderBy=startTime`,
  );

  if (!meetingsRes.ok || !eventsRes.ok) {
    throw new Error("Calendar API error");
  }

  const meetingsData = await meetingsRes.json();
  const eventsData = await eventsRes.json();

  nextMeeting = meetingsData.items?.[0] || null;
  upcomingEvents = eventsData.items || [];
} catch (error) {
  console.error("Calendar fetch error:", error);
  calendarError = true;
}

// 🔄 Fetch posts, sorting by eventDate (Newest event at the top)
const posts = await sanityClient.fetch<Array<any>>(`
  *[_type == "post"] | order(coalesce(eventDate, _createdAt) desc) [0...4] {
    title,
    slug,
    eventDate,
    _createdAt,
    author,
    mainImage,
    excerpt
  }
`);

// Fetch hero image and alt text from siteSettings
const siteSettings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    heroImage,
    heroImageAlt
  }
`);

const getEventDateInfo = (dateStr: string) => {
  const d = new Date(dateStr);
  return {
    month: d.toLocaleString("en-US", {
      month: "short",
      timeZone: "America/Chicago",
    }),
    day: d.toLocaleString("en-US", {
      day: "numeric",
      timeZone: "America/Chicago",
    }),
    time: d.toLocaleTimeString("en-US", {
      hour: "2-digit",
      minute: "2-digit",
      timeZone: "America/Chicago",
    }),
  };
};
---

<Layout
  title="Boy Scout Troop 747 | Brentwood, TN"
  description="Building character, leadership, and adventure since 2008."
>
  <div
    class="max-w-[1440px] 2xl:max-w-[1800px] mx-auto px-4 sm:px-8 md:px-12 lg:px-16 w-full py-12"
  >
    <section id="about" class="pt-20 pb-16">
      <div class="flex flex-col lg:flex-row items-center gap-12">
        <div class="flex-1 text-center sm:text-left">
          <h1
            class="text-4xl sm:text-6xl 2xl:text-7xl font-extrabold tracking-tight text-slate-900 leading-tight"
          >
            Building character, leadership, and <span class="text-emerald-700"
              >adventure</span
            > since 2008.
          </h1>
          <p
            class="mt-6 text-lg sm:text-xl 2xl:text-2xl text-slate-600 leading-relaxed max-w-3xl"
          >
            Welcome to Boy Scout Troop 747. Chartered out of Brentwood,
            Tennessee, we provide a youth-led program focused on outdoor
            adventure, community service, and lifelong leadership skills.
          </p>
        </div>

        {
          siteSettings?.heroImage && (
            <div class="flex-1 w-full max-w-md lg:max-w-lg shrink-0">
              <img
                src={urlFor(siteSettings.heroImage)
                  .width(800)
                  .auto("format")
                  .quality(85)
                  .url()}
                srcset={buildSrcSet(
                  siteSettings.heroImage,
                  [400, 800, 1200],
                  85,
                )}
                alt={siteSettings.heroImageAlt || "Troop 747 Scouts"}
                class="w-full h-auto rounded-2xl shadow-lg object-cover aspect-[4/5]"
              />
            </div>
          )
        }
      </div>
    </section>

    <hr class="border-slate-200 my-4" />
    <section id="calendar" class="py-12 w-full">
      <div
        class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-8 gap-2 w-full"
      >
        <div>
          <h2
            class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900"
          >
            Upcoming Troop Schedule
          </h2>
          <p class="text-sm text-slate-500 mt-1">
            Live data pulled natively from our Google Calendar
          </p>
        </div>
        <span
          class="text-xs font-medium text-emerald-800 bg-emerald-50 px-3 py-1 rounded-full border border-emerald-200/60 self-start"
        >
          Dynamic API Feed
        </span>
      </div>

      {
        calendarError ? (
          <div class="w-full p-8 rounded-2xl border-2 border-dashed border-slate-200 bg-white text-center text-slate-500">
            <span class="text-2xl block mb-2">📅</span>
            <p class="font-medium text-slate-700">
              Calendar unavailable right now.
            </p>
          </div>
        ) : (
          <div class="flex flex-col gap-8">
            {nextMeeting &&
              (() => {
                const d = getEventDateInfo(
                  nextMeeting.start.dateTime || nextMeeting.start.date,
                );
                return (
                  <div class="bg-emerald-50 border border-emerald-200 rounded-2xl p-5 flex items-center gap-5">
                    <div class="bg-emerald-700 text-white rounded-xl p-3 text-center min-w-[64px] shrink-0">
                      <span class="block text-xs font-bold uppercase tracking-wider">
                        {d.month}
                      </span>
                      <span class="block text-2xl font-black leading-none mt-0.5">
                        {d.day}
                      </span>
                    </div>
                    <div class="flex-1">
                      <span class="text-xs font-bold uppercase tracking-wider text-emerald-700">
                        Next Troop Meeting
                      </span>
                      <h3 class="font-bold text-lg text-slate-900 mt-0.5">
                        {nextMeeting.summary}
                      </h3>
                      {nextMeeting.location && (
                        <p class="text-xs text-slate-500 mt-1">
                          📍 {nextMeeting.location}
                        </p>
                      )}
                      <p class="text-xs text-slate-400 mt-1">
                        {nextMeeting.start.dateTime
                          ? `⏰ ${d.time}`
                          : "📅 All Day"}
                      </p>
                    </div>
                  </div>
                );
              })()}

            {upcomingEvents.length === 0 ? (
              <div class="w-full p-8 rounded-2xl border-2 border-dashed border-slate-200 bg-white text-center text-slate-500">
                <span class="text-2xl block mb-2">🏕️</span>
                <p class="font-medium text-slate-700">
                  No upcoming troop events scheduled yet.
                </p>
                <p class="text-xs text-slate-400 mt-1">Check back soon!</p>
              </div>
            ) : (
              <div>
                <h3 class="text-lg font-bold text-slate-800 mb-4">
                  Upcoming Troop Events
                </h3>
                <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                  {upcomingEvents.map((event: any) => {
                    const d = getEventDateInfo(
                      event.start.dateTime || event.start.date,
                    );
                    return (
                      <div class="bg-white p-6 rounded-2xl border border-slate-200 hover:border-emerald-500/40 hover:shadow-md transition duration-300 group flex flex-col justify-between">
                        <div class="flex justify-between items-start gap-4">
                          <div class="bg-emerald-50 text-emerald-800 rounded-xl p-3 text-center min-w-[64px] border border-emerald-100 shrink-0">
                            <span class="block text-xs font-bold uppercase tracking-wider">
                              {d.month}
                            </span>
                            <span class="block text-2xl font-black leading-none mt-0.5">
                              {d.day}
                            </span>
                          </div>
                          <div class="flex-1">
                            <h3 class="font-bold text-lg text-slate-900 group-hover:text-emerald-800 transition line-clamp-2">
                              {event.summary}
                            </h3>
                            {event.location && (
                              <p class="text-xs text-slate-500 mt-1 line-clamp-1">
                                📍 {event.location}
                              </p>
                            )}
                          </div>
                        </div>
                        <div class="text-xs text-slate-400 font-medium mt-4 border-t border-slate-100 pt-3">
                          {event.start.dateTime
                            ? `⏰ ${d.time}`
                            : "📅 All Day Event"}
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            )}

            <div class="text-right">
              <a
                href="/calendar"
                class="inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 hover:text-emerald-800 transition group"
              >
                View Full Calendar
                <span class="transition-transform group-hover:translate-x-1">
                  →
                </span>
              </a>
            </div>
          </div>
        )
      }
    </section>

    <hr class="border-slate-200 my-4" />

    <section id="news" class="py-12 mb-12 w-full">
      <div class="mb-8">
        <h2
          class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900"
        >
          Recent News & Highlights
        </h2>
        <p class="text-sm text-slate-500 mt-1">
          Stories written by our scouts and leaders, managed via Sanity
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 w-full">
        {
          posts.map((post) => (
            <article class="flex flex-col xl:flex-row gap-6 bg-white p-5 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition duration-300">
              <div class="w-full xl:w-56 h-48 xl:h-auto rounded-xl overflow-hidden shrink-0 shadow-inner relative flex items-center justify-center bg-slate-100">
                {post.mainImage ? (
                  <img
                    src={urlFor(post.mainImage)
                      .width(500)
                      .auto("format")
                      .quality(80)
                      .url()}
                    srcset={buildSrcSet(post.mainImage, [300, 500], 80)}
                    alt={post.mainImage.alt || post.title}
                    class="w-full h-full object-cover transition duration-500 hover:scale-105"
                  />
                ) : (
                  <div class="w-full h-full bg-[#1e293b] flex items-center justify-center p-6">
                    <img
                      src="/images/logo.png"
                      alt="BSA Troop 747 Logo"
                      class="max-w-full max-h-full object-contain select-none pointer-events-none"
                    />
                  </div>
                )}
              </div>

              <div class="flex flex-col justify-between py-1 flex-1">
                <div>
                  <time class="text-xs font-semibold text-emerald-700 tracking-wider uppercase">
                    📅{" "}
                    {post.eventDate
                      ? formatDate(post.eventDate)
                      : formatDate(post._createdAt)}
                  </time>
                  <h3 class="text-2xl font-bold text-slate-900 mt-1 hover:text-emerald-700 transition leading-snug">
                    <a href={`/post/${post.slug.current}`}>{post.title}</a>
                  </h3>
                  <p class="text-sm text-slate-600 mt-3 line-clamp-3 leading-relaxed">
                    {post.excerpt ||
                      "Click to read the full details of this recent post."}
                  </p>
                </div>

                {post.author && (
                  <div class="flex items-center gap-2 mt-6">
                    <div class="w-7 h-7 rounded-full bg-emerald-800 flex items-center justify-center text-[10px] font-bold text-white shadow-sm">
                      🪶
                    </div>
                    <span class="text-xs font-bold text-slate-700">
                      {post.author}
                    </span>
                  </div>
                )}
              </div>
            </article>
          ))
        }
      </div>
      <div class="text-right mt-4">
        <a
          href="/news"
          class="inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 hover:text-emerald-800 transition group"
        >
          View All News
          <span class="transition-transform group-hover:translate-x-1">→</span>
        </a>
      </div>
    </section>
    <hr class="border-slate-200 my-4" />

    <section id="contact" class="py-12 w-full">
      <div class="mb-10">
        <h2
          class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900"
        >
          Contact Us
        </h2>
        <p class="text-sm text-slate-500 mt-1">
          Everything you need to visit, join, or reach out.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {/* Location */}
        <div class="bg-white p-6 rounded-2xl border border-slate-200">
          <div
            class="w-10 h-10 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center mb-4 text-lg"
          >
            📍
          </div>
          <h3 class="font-bold text-slate-900 mb-2">Location</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            Covenant Presbyterian Church<br />
            33 Burton Hills Blvd<br />
            Nashville, TN 37215
          </p>
        </div>

        {/* Email */}
        <div class="bg-white p-6 rounded-2xl border border-slate-200">
          <div
            class="w-10 h-10 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center mb-4 text-lg"
          >
            ✉️
          </div>
          <h3 class="font-bold text-slate-900 mb-2">Email</h3>

          <a
            href="mailto:ScoutMeIn@Scouting747.com"
            class="text-sm text-emerald-700 hover:text-emerald-800 font-semibold transition break-words"
          >
            ScoutMeIn@Scouting747.com
          </a>
        </div>

        {/* Join Our Troop */}
        <div class="bg-white p-6 rounded-2xl border border-slate-200">
          <div
            class="w-10 h-10 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center mb-4 text-lg"
          >
            🪶
          </div>
          <h3 class="font-bold text-slate-900 mb-2">Join Our Troop</h3>
          <p class="text-sm text-slate-600 leading-relaxed mb-3">
            Fill out an application online.
          </p>

          <a
            href="https://my.scouting.org/VES/OnlineReg/1.0.0/?tu=UF-MB-560taa0747"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-sm font-semibold text-emerald-700 hover:text-emerald-800 transition group"
          >
            Apply Now
            <span class="transition-transform group-hover:translate-x-1">→</span
            >
          </a>
        </div>

        {/* Weekly Meetings */}
        <div class="bg-white p-6 rounded-2xl border border-slate-200">
          <div
            class="w-10 h-10 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center mb-4 text-lg"
          >
            🗓️
          </div>
          <h3 class="font-bold text-slate-900 mb-2">Weekly Meetings</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            Most Mondays<br />
            6:30 PM – 8:00 PM
          </p>
        </div>
      </div>
    </section>
  </div>
</Layout>; ---
