---
import Layout from "../layouts/Layout.astro";
import { urlFor, buildSrcSet } from "../utils/image";
import { formatDate } from "../utils";

// 1. Fetch your live Sanity posts for the bottom section
import { sanityClient } from "sanity:client";
const posts = await sanityClient.fetch<Array<any>>(
  `*[_type == "post" && defined(slug.current)] | order(_createdAt desc)[0..1]`
);
---

<Layout title="Boy Scout Troop 747 | Brentwood, TN" description="Building character, leadership, and adventure since 2001.">
  <section id="about" class="max-w-6xl mx-auto px-6 pt-20 pb-16 text-center sm:text-left">
    <div class="max-w-[1440px] 2xl:max-w-[1800px] mx-auto px-4 sm:px-8 md:px-12 lg:px-16">
      <h1 class="text-4xl sm:text-6xl font-bold tracking-tight text-slate-900 leading-tight">
        Building character, leadership, and <span class="text-emerald-700">adventure</span> since 2001.
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-slate-600 leading-relaxed">
        Welcome to Boy Scout Troop 747. Chartered out of Brentwood, Tennessee, we provide a youth-led program focused on outdoor adventure, community service, and lifelong leadership skills.
      </p>
    </div>
  </section>

  <hr class="max-w-6xl mx-auto border-slate-200 my-4" />

  <section id="calendar" class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col sm:flex-row sm:items-baseline justify-between mb-8 gap-2">
      <div>
        <h2 class="text-2xl font-bold tracking-tight text-slate-900">Upcoming Troop Schedule</h2>
        <p class="text-sm text-slate-500 mt-1">Live data pulled natively from our Google Calendar</p>
      </div>
      <span class="text-xs font-medium text-emerald-800 bg-emerald-50 px-3 py-1 rounded-full border border-emerald-200/60 self-start">Updated 1 hour ago</span>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <div class="bg-white p-5 rounded-2xl border border-slate-200 hover:border-emerald-500/40 hover:shadow-sm transition group">
        <div class="flex justify-between items-start gap-4">
          <div class="bg-emerald-50 text-emerald-800 rounded-xl p-3 text-center min-w-[56px] border border-emerald-100">
            <span class="block text-xs font-bold uppercase tracking-wider">Jul</span>
            <span class="block text-xl font-bold leading-none mt-0.5">17</span>
          </div>
          <div class="flex-1">
            <span class="inline-flex items-center text-xs font-semibold px-2 py-0.5 rounded bg-amber-50 text-amber-800 border border-amber-200/60 mb-2">🏕️ Campout</span>
            <h3 class="font-semibold text-slate-900 group-hover:text-emerald-800 transition">Summer Whitewater Rafting</h3>
            <p class="text-xs text-slate-500 mt-1">Ocoee River, TN</p>
            <p class="text-xs text-slate-400 mt-0.5">All Day Event</p>
          </div>
        </div>
      </div>

      <div class="bg-white p-5 rounded-2xl border border-slate-200 hover:border-emerald-500/40 hover:shadow-sm transition group">
        <div class="flex justify-between items-start gap-4">
          <div class="bg-slate-100 text-slate-700 rounded-xl p-3 text-center min-w-[56px] border border-slate-200">
            <span class="block text-xs font-bold uppercase tracking-wider">Jul</span>
            <span class="block text-xl font-bold leading-none mt-0.5">21</span>
          </div>
          <div class="flex-1">
            <span class="inline-flex items-center text-xs font-semibold px-2 py-0.5 rounded bg-blue-50 text-blue-800 border border-blue-200/60 mb-2">⚜️ Troop Meeting</span>
            <h3 class="font-semibold text-slate-900 group-hover:text-emerald-800 transition">PLC & Advancement Prep</h3>
            <p class="text-xs text-slate-500 mt-1">Troop Hut</p>
            <p class="text-xs text-slate-400 mt-0.5">7:00 PM - 8:30 PM</p>
          </div>
        </div>
      </div>

      <div class="bg-white p-5 rounded-2xl border border-slate-200 hover:border-emerald-500/40 hover:shadow-sm transition group">
        <div class="flex justify-between items-start gap-4">
          <div class="bg-slate-100 text-slate-700 rounded-xl p-3 text-center min-w-[56px] border border-slate-200">
            <span class="block text-xs font-bold uppercase tracking-wider">Aug</span>
            <span class="block text-xl font-bold leading-none mt-0.5">04</span>
          </div>
          <div class="flex-1">
            <span class="inline-flex items-center text-xs font-semibold px-2 py-0.5 rounded bg-purple-50 text-purple-800 border border-purple-200/60 mb-2">🎖️ Special Event</span>
            <h3 class="font-semibold text-slate-900 group-hover:text-emerald-800 transition">Summer Court of Honor</h3>
            <p class="text-xs text-slate-500 mt-1">Main Sanctuary</p>
            <p class="text-xs text-slate-400 mt-0.5">6:30 PM</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="max-w-6xl mx-auto border-slate-200 my-4" />

  <section id="news" class="max-w-6xl mx-auto px-6 py-12">
    <div class="mb-8">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Recent News & Highlights</h2>
      <p class="text-sm text-slate-500 mt-1">Stories written by our scouts and leaders, managed via Sanity</p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {posts.map((post) => (
        <article class="flex flex-col sm:flex-row gap-6 bg-white p-4 rounded-2xl border border-slate-200">
          <div class="w-full sm:w-48 h-48 sm:h-auto rounded-xl bg-slate-100 overflow-hidden shrink-0">
            {post.mainImage ? (
              <img 
                src={urlFor(post.mainImage).width(400).auto("format").quality(80).url()} 
                srcset={buildSrcSet(post.mainImage, [200, 400], 80)}
                alt={post.mainImage.alt || post.title} 
                class="w-full h-full object-cover"
              />
            ) : (
              <div class="w-full h-full bg-slate-200 flex items-center justify-center text-slate-400">No Image</div>
            )}
          </div>
          <div class="flex flex-col justify-between py-2">
            <div>
              <time class="text-xs font-medium text-slate-400">{formatDate(post._createdAt)}</time>
              <h3 class="text-xl font-bold text-slate-900 mt-1 hover:text-emerald-700 transition">
                <a href={`/post/${post.slug.current}`}>{post.title}</a>
              </h3>
              <p class="text-sm text-slate-600 mt-2 line-clamp-3">
                {post.excerpt}
              </p>
            </div>
            {post.author && (
              <div class="flex items-center gap-2 mt-4 sm:mt-0">
                <div class="w-6 h-6 rounded-full bg-emerald-800 flex items-center justify-center text-[10px] font-bold text-white">🪶</div>
                <span class="text-xs font-semibold text-slate-700">{post.author.name}</span>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>