---
import { VisualEditing } from "@sanity/astro/visual-editing";
import "../styles/global.css";
// Import your new logo asset from the assets folder
import troopLogo from "../assets/747-logo-wt.png";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const canonicalURL = Astro.url;

// Enable visual editing overlays when the env variable is set to "true"
const visualEditingEnabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED === "true";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    {description && <meta name="description" content={description} />}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {image && <meta property="og:image" content={image} />}

    <meta
      name="twitter:card"
      content={image ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {image && <meta name="twitter:image" content={image} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@500;700&family=Inter:wght@500;700;800&family=PT+Serif:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="bg-slate-50 text-slate-900 antialiased font-sans">
    <VisualEditing enabled={visualEditingEnabled} />

    <header
      class="sticky top-0 z-50 bg-slate-900/95 backdrop-blur-md border-b border-slate-800 relative"
    >
      <div
        class="max-w-[1440px] 2xl:max-w-[1800px] mx-auto px-4 sm:px-8 md:px-12 lg:px-16 h-20 flex items-center justify-between"
      >
        <a href="/" class="flex items-center gap-4 group transition">
          <img
            src={troopLogo.src}
            alt="BSA Troop 747 Logo"
            class="h-10 sm:h-12 md:h-14 w-auto object-contain brightness-100 group-hover:opacity-90 transition"
          />
          <div class="hidden md:flex flex-col border-l border-slate-700 pl-4">
            <span
              class="text-xs font-bold tracking-widest text-emerald-400 uppercase"
              >Boy Scouts of America</span
            >
            <span class="text-xs font-medium text-slate-400">Brentwood, TN</span
            >
          </div>
        </a>

        <nav x-data="{ open: false }" class="flex items-center">
          {/* Desktop nav */}
          <div
            class="hidden md:flex items-center gap-5 sm:gap-8 lg:gap-12 text-sm sm:text-base font-semibold text-slate-300"
          >
            <a href="/#about" class="hover:text-emerald-400 transition">About</a
            >
            <a href="/#calendar" class="hover:text-emerald-400 transition"
              >Calendar</a
            >
            <a href="/#news" class="hover:text-emerald-400 transition"
              >News & Blog</a
            >
            <a href="/history" class="hover:text-emerald-400 transition"
              >History</a
            >
            <a href="/#contact" class="hover:text-emerald-400 transition"
              >Contact</a
            >
          </div>

          {/* Mobile hamburger button */}
          <button
            onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
            class="md:hidden flex flex-col gap-1.5 p-2 text-slate-300 hover:text-emerald-400 transition"
            aria-label="Toggle menu"
          >
            <span class="block w-6 h-0.5 bg-current"></span>
            <span class="block w-6 h-0.5 bg-current"></span>
            <span class="block w-6 h-0.5 bg-current"></span>
          </button>
        </nav>

        {/* Mobile dropdown menu */}
        <div
          id="mobile-menu"
          class="hidden md:hidden absolute top-20 left-0 right-0 bg-slate-900 border-b border-slate-800 z-50"
        >
          <div
            class="flex flex-col px-4 py-4 gap-4 text-sm font-semibold text-slate-300"
          >
            <a href="/#about" class="hover:text-emerald-400 transition">About</a
            >
            <a href="/#calendar" class="hover:text-emerald-400 transition"
              >Calendar</a
            >
            <a href="/#news" class="hover:text-emerald-400 transition"
              >News & Blog</a
            >
            <a href="/history" class="hover:text-emerald-400 transition"
              >History</a
            >
            <a href="/#contact" class="hover:text-emerald-400 transition"
              >Contact</a
            >
          </div>
        </div>
      </div>
    </header>

    <main class="w-full">
      <slot />
    </main>

    <footer class="bg-slate-950 text-slate-400 mt-20 border-t border-slate-900">
      <div
        class="max-w-[1440px] 2xl:max-w-[1800px] mx-auto px-6 sm:px-12 py-12 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm"
      >
        <p>
          &copy; {new Date().getFullYear()} BSA Troop 747 Brentwood, TN. All rights
          reserved.
        </p>
        <p class="text-slate-600 flex items-center gap-1">
          Built with Astro & Sanity
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* Sets the clean modern look globally across the whole platform */
  body {
    font-family: "Plus Jakarta Sans", sans-serif;
  }
</style>
